{
  "name": "mezentsevs/task-manager",
  "private": true,
  "type": "module",
  "description": "Task manager",
  "keywords": [
    "nuxt",
    "vue",
    "framework",
    "task",
    "manager"
  ],
  "license": "MIT",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "vue:lint": "eslint . --ext .vue",
    "vue:lint:fix": "eslint . --ext .vue --fix",
    "ts:lint": "eslint . --ext .ts",
    "ts:lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --check \"**/*.{js,ts,vue}\"",
    "format:fix": "prettier --write \"**/*.{js,ts,vue}\"",
    "code:lint": "npm run lint && npm run vue:lint && npm run format",
    "code:fix": "npm run format:fix && npm run lint:fix && npm run vue:lint:fix"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "axios": "^1.18.1",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.7.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "vue-eslint-parser": "^10.4.1"
  }
}
